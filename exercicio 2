# conversor de medidas:crie um programa que receba um valor em metros e o exiba convertido em centimetros e milimetros
m1=float(input("digite a medida em metros:" ))
centimetros = m1* 100
milimetros = m1* 1000
print ("a medida em centimetros é de:" , centimetros ,"CM")
print ("a medida em milimetros é de:" , milimetros ,"MM")
